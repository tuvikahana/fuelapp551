generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("field_user")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  odometerReadings OdometerReading[]
  refuelEvents     RefuelEvent[]

  @@map("users")
}

model VehicleType {
  id                        String   @id @default(cuid())
  name                      String   @unique
  fuelTankCapacityLiters    Float    @map("fuel_tank_capacity_liters")
  estimatedKmPerLiter       Float    @map("estimated_km_per_liter")
  fuelBandThreshold75       Float    @default(75) @map("fuel_band_threshold_75")
  fuelBandThreshold50       Float    @default(50) @map("fuel_band_threshold_50")
  fuelBandThreshold25       Float    @default(25) @map("fuel_band_threshold_25")
  fuelBandThreshold10       Float    @default(10) @map("fuel_band_threshold_10")
  actionThresholdPlanRefuel Float    @default(35) @map("action_threshold_plan_refuel")
  actionThresholdRefuelSoon Float    @default(20) @map("action_threshold_refuel_soon")
  actionThresholdRefuelNow  Float    @default(10) @map("action_threshold_refuel_now")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  vehicles Vehicle[]

  @@map("vehicle_types")
}

model Vehicle {
  id                      String   @id @default(cuid())
  vehicleNumber           String   @unique @map("vehicle_number")
  vehicleTypeId           String   @map("vehicle_type_id")
  nickname                String?
  notes                   String?
  lastFullRefuelOdometer  Float?   @map("last_full_refuel_odometer")
  latestConfirmedOdometer Float?   @map("latest_confirmed_odometer")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  vehicleType      VehicleType       @relation(fields: [vehicleTypeId], references: [id])
  odometerReadings OdometerReading[]
  refuelEvents     RefuelEvent[]

  @@map("vehicles")
}

model OdometerReading {
  id             String   @id @default(cuid())
  vehicleId      String   @map("vehicle_id")
  userId         String?  @map("user_id")
  inputMethod    String   @map("input_method")
  ocrValue       Float?   @map("ocr_value")
  confirmedValue Float    @map("confirmed_value")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@map("odometer_readings")
}

model RefuelEvent {
  id               String   @id @default(cuid())
  vehicleId        String   @map("vehicle_id")
  userId           String?  @map("user_id")
  eventType        String   @default("full_refuel") @map("event_type")
  odometerAtRefuel Float    @map("odometer_at_refuel")
  createdAt        DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@map("refuel_events")
}
